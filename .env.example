# Copy this to .env (which is gitignored)
# Register an Azure app at https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
# Set platform to "Mobile and desktop applications"
# Add redirect URI: https://login.microsoftonline.com/common/oauth2/nativeclient
# Required API permissions: Microsoft Graph > Tasks.ReadWrite, User.Read (Delegated)
AZURE_CLIENT_ID=your-client-id-here
